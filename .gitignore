# Keep only stable Beads files in git; ignore local runtime artifacts.
.beads/*
!.beads/.gitignore
!.beads/config.yaml
!.beads/issues.jsonl

.idea/
*.pyc
*.pyo
*.pyd
*.sqlite3
*.log
**/__pycache__/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
backend/.venv/
backend/data/*.db
backend/data/*.db-*
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js
.env
site.conf